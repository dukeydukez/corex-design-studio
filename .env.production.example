# ── COREX Design Studio — Production Environment ──
# Copy this to .env and fill in your values before deploying

# Domain
DOMAIN=studio.corexcreative.com

# Database
POSTGRES_USER=corex
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=corex_design

# Redis
REDIS_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Authentication (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# AI (optional, for agent features)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Email for SSL certificate notifications
CERTBOT_EMAIL=dwayne@corexcreative.com
