# Backend Environment Variables - Copy to .env and fill in your values

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# DATABASE - PostgreSQL
# ============================================================================
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/corex"
# For production, use a more secure password and separate host

# ============================================================================
# CACHING - Redis
# ============================================================================
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================================
# AUTHENTICATION - JWT Tokens
# ============================================================================
# Generate secure random strings for these in production
JWT_SECRET="your-super-secret-jwt-key-change-in-production-use-random-string"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production-use-random-string"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================================================
# AI / LLM - Claude API
# ============================================================================
# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-your-api-key-here"
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# ============================================================================
# IMAGE GENERATION (Optional)
# ============================================================================
# DALLE_API_KEY="sk-your-dalle-key"
# MIDJOURNEY_API_KEY="your-midjourney-key"

# ============================================================================
# CLOUD STORAGE - AWS S3
# ============================================================================
# Get credentials from AWS console
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="corex-designs-dev"

# ============================================================================
# CORS - Frontend URLs
# ============================================================================
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS=3600000  # 1 hour
RATE_LIMIT_MAX_REQUESTS=1000

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_AGENT_LOGGING=true
ENABLE_DESIGN_VERSIONING=true
ENABLE_COLLABORATIVE_EDITING=false
ENABLE_EXPORT_QUEUE=true
