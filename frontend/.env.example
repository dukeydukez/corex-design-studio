# Frontend Environment Variables

NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Auth
NEXT_PUBLIC_AUTH_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_AUTH_GITHUB_CLIENT_ID=your-github-client-id

# Analytics
NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id

# Feature Flags
NEXT_PUBLIC_ENABLE_BETA_FEATURES=false
NEXT_PUBLIC_ENABLE_DEBUGGING=false

# Canvas Settings
NEXT_PUBLIC_CANVAS_MAX_ZOOM=500
NEXT_PUBLIC_CANVAS_MIN_ZOOM=10
NEXT_PUBLIC_CANVAS_GRID_ENABLED=true
NEXT_PUBLIC_CANVAS_GRID_SIZE=16
